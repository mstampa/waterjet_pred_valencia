{
  "$schema": "https://opencode.ai/config.json",

  "permission": {
    "external_directory": {
      // Allow access to the parent workspace and sibling repositories.
      "$HOME/work/narf/**": "allow"
    },

    "edit": {
      // Ask before editing sibling repositories in the shared workspace.
      "$HOME/work/narf/*/**": "ask",

      // Keep normal edit behavior inside this repository.
      "$HOME/work/narf/waterjet_pred_valencia/**": "allow"
    }
  }
}
